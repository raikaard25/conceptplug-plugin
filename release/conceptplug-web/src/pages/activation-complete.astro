---
import Base from '../layouts/Base.astro';

const status = Astro.url.searchParams.get('status') || '';
const site = Astro.url.searchParams.get('site') || '';

const isSuccess = status === 'success';
const isInvalid = status === 'invalid';
const isCancelled = status === 'cancelled';
---

<Base
	title="ConceptPlug activation"
	description="Finish your ConceptPlug email activation and return to WordPress."
>
	<section class="border-b border-slate-200 bg-cp-surface py-16">
		<div class="mx-auto max-w-3xl px-4 sm:px-6">
			<p class="text-sm font-semibold uppercase tracking-wide text-cp-primary">Activation</p>
			<h1 class="mt-2 text-3xl font-bold text-slate-900 sm:text-4xl">ConceptPlug activation</h1>
		</div>
	</section>
	<section class="border-t border-slate-200 bg-white py-16">
		<div class="mx-auto max-w-3xl px-4 sm:px-6">
			<div class="rounded-2xl border border-slate-200 bg-cp-surface p-8">
				{isSuccess && (
					<>
						<h2 class="text-2xl font-bold text-emerald-700">Email confirmed</h2>
						{site ? (
							<p class="mt-4 text-slate-700">
								Activated for <strong class="break-all text-slate-900">{site}</strong>
							</p>
						) : (
							<p class="mt-4 text-slate-700">Your email was confirmed successfully.</p>
						)}
						<p class="mt-4 text-slate-700">
							Return to WordPress — activation finishes automatically when the plugin detects confirmation.
						</p>
					</>
				)}
				{isInvalid && (
					<>
						<h2 class="text-2xl font-bold text-red-700">Link invalid or expired</h2>
						<p class="mt-4 text-slate-700">
							This activation link is invalid or has expired. Start activation again from your WordPress dashboard.
						</p>
					</>
				)}
				{isCancelled && (
					<>
						<h2 class="text-2xl font-bold text-slate-900">Activation not confirmed</h2>
						<p class="mt-4 text-slate-700">
							You chose not to activate this site. No changes were made. If this was a mistake, start activation again from WordPress.
						</p>
					</>
				)}
				{!isSuccess && !isInvalid && !isCancelled && (
					<>
						<h2 class="text-2xl font-bold text-slate-900">Check WordPress</h2>
						<p class="mt-4 text-slate-700">Return to WordPress to check your activation status.</p>
					</>
				)}
				<p class="mt-8 text-sm text-slate-600">
					<a href="/download" class="font-medium text-cp-primary hover:underline">Download ConceptPlug</a>
					{' '}
					if you have not installed the plugin yet.
				</p>
			</div>
		</div>
	</section>
</Base>
