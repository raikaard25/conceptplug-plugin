{
  "name": "conceptplug/conceptplug",
  "description": "Development-only quality tooling for the public ConceptPlug WordPress plugin.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "php-stubs/woocommerce-stubs": "^9.0 || ^10.0",
    "phpstan/phpstan": "^1.12",
    "squizlabs/php_codesniffer": "^3.10",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "wp-coding-standards/wpcs": "^3.1"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "sort-packages": true
  },
  "scripts": {
    "lint:phpcs": "phpcs --standard=phpcs.xml.dist",
    "analyse": "phpstan analyse --configuration=phpstan.neon.dist --no-progress"
  }
}
